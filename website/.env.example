# MovIO website (landing + survey) — environment.
# Copy to .env.local and fill in from your Supabase project → Settings → API.
# .env.local is gitignored (root .gitignore covers .env / .env.local monorepo-wide).
#
# NOTE: this site uses the SAME Supabase project as the backend. The survey /
# waitlist tables (website/supabase/schema.sql) live in that one shared project
# alongside the app tables (backend/db/schema.sql) — one project, one URL.
# The site talks to it directly with the publishable/anon key (RLS-gated), which
# is why the survey/waitlist tables need their own RLS policies (unlike the app
# tables, which are locked to the backend's postgres role).

VITE_SUPABASE_URL=

# Prefer Supabase's newer "publishable" key (sb_publishable_…). The legacy anon
# key still works via VITE_SUPABASE_ANON_KEY as a fallback.
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=

# ── Live map (public, no auth) ──────────────────────────────────────────────
# The live map reads active-trip data from the MovIO backend (Express REST +
# Socket.io), NOT from Supabase — the app tables are locked to the backend's
# postgres role, so the anon key can't read them. Point these at the backend.
#
# Local dev: leave as-is (backend runs on :4000 via `cd backend && yarn dev`).
# Deployed: set to the Render backend URL, e.g. https://movio-backend.onrender.com
# (note Render's free tier cold-starts ~30-60s after idle — the map shows a
# "waking up" state and retries, so this degrades gracefully).
VITE_API_BASE_URL=http://localhost:4000
# Socket.io endpoint — defaults to VITE_API_BASE_URL if unset (same host).
# VITE_SOCKET_URL=http://localhost:4000

# ── Transit Credit top-up (Paystack) ────────────────────────────────────────
# Paystack PUBLIC key (pk_test_… in development). The Paystack popup on the
# /topup page uses the access_code the backend returns, so the public key isn't
# strictly required by the current inline flow — but keep it here for the
# standard Paystack setup and any future direct-init usage. The SECRET key lives
# ONLY in the backend, never in this frontend.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
